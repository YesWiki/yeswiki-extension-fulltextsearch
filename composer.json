{
  "require": {
    "php": ">=8.2",
    "cmsig/seal": "^0.10",
    "cmsig/seal-loupe-adapter": "^0.10",
    "doctrine/lexer": "^2.0",
    "smalot/pdfparser": "^2.12",
    "cmsig/seal-typesense-adapter": "^0.10",
    "loupe/matcher": "^0.2"
  },
  "autoload": {
    "psr-4": {
      "\\YesWiki\\FullTextSearch\\Services\\": "services",
      "\\YesWiki\\FullTextSearch\\DTO\\": "dto",
      "\\YesWiki\\FullTextSearch\\Enum\\": "enum",
      "\\YesWiki\\FullTextSearch\\Exception\\": "exception"
    }
  },
  "extra": {
    "patches": {
      "loupe/loupe": {
        "Fix null array offset deprecation in Tokenizer": "patches/loupe-tokenizer-null-language-key.patch"
      }
    }
  },
  "config": {
    "allow-plugins": {
      "php-http/discovery": false,
      "cweagans/composer-patches": true
    }
  },
  "require-dev": {
    "cweagans/composer-patches": "^2.0"
  }
}
